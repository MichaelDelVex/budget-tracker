{
  "info": {
    "name": "Budget Tracker API",
    "description": "Local Budget Tracker API collection.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Get API Health",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/health",
              "host": ["{{baseUrl}}"],
              "path": ["api", "health"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Accounts",
      "item": [
        {
          "name": "List Accounts",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/accounts",
              "host": ["{{baseUrl}}"],
              "path": ["api", "accounts"]
            }
          },
          "response": []
        },
        {
          "name": "Get Account",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/accounts/{{accountId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "accounts", "{{accountId}}"]
            }
          },
          "response": []
        },
        {
          "name": "Create Account",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Everyday\",\n  \"bank\": \"Example Bank\",\n  \"accountType\": \"CHECKING\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/accounts",
              "host": ["{{baseUrl}}"],
              "path": ["api", "accounts"]
            }
          },
          "response": []
        },
        {
          "name": "Update Account",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Everyday\",\n  \"bank\": \"Example Bank\",\n  \"accountType\": \"SAVINGS\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/accounts/{{accountId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "accounts", "{{accountId}}"]
            }
          },
          "response": []
        },
        {
          "name": "Delete Account",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/accounts/{{accountId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "accounts", "{{accountId}}"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Transactions",
      "item": [
        {
          "name": "Get Transactions",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/transactions?dateFrom=2026-01-01&dateTo=2026-01-31&accountId={{accountId}}&categoryId={{categoryId}}&tagId={{tagId}}&direction=EXPENSE&search=coffee&page=0&size=25",
              "host": ["{{baseUrl}}"],
              "path": ["api", "transactions"],
              "query": [
                {
                  "key": "dateFrom",
                  "value": "2026-01-01"
                },
                {
                  "key": "dateTo",
                  "value": "2026-01-31"
                },
                {
                  "key": "accountId",
                  "value": "{{accountId}}"
                },
                {
                  "key": "categoryId",
                  "value": "{{categoryId}}"
                },
                {
                  "key": "tagId",
                  "value": "{{tagId}}"
                },
                {
                  "key": "direction",
                  "value": "EXPENSE"
                },
                {
                  "key": "search",
                  "value": "coffee"
                },
                {
                  "key": "page",
                  "value": "0"
                },
                {
                  "key": "size",
                  "value": "25"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get Transaction By ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/transactions/{{transactionId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "transactions", "{{transactionId}}"]
            }
          },
          "response": []
        },
        {
          "name": "Update Transaction",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"accountId\": 1,\n  \"transactionDate\": \"2026-01-10\",\n  \"description\": \"Coffee\",\n  \"rawDescription\": \"COFFEE SHOP\",\n  \"amount\": 4.50,\n  \"direction\": \"EXPENSE\",\n  \"categoryId\": 2,\n  \"tagId\": 1,\n  \"importBatchId\": null\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/transactions/{{transactionId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "transactions", "{{transactionId}}"]
            }
          },
          "response": []
        },
        {
          "name": "Delete Transaction",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/transactions/{{transactionId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "transactions", "{{transactionId}}"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Imports",
      "item": [
        {
          "name": "Import Transactions CSV",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "accountId",
                  "value": "{{accountId}}",
                  "type": "text"
                },
                {
                  "key": "file",
                  "type": "file",
                  "src": []
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/imports/transactions",
              "host": ["{{baseUrl}}"],
              "path": ["api", "imports", "transactions"]
            }
          },
          "response": []
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "accountId",
      "value": "1"
    },
    {
      "key": "transactionId",
      "value": "1"
    },
    {
      "key": "categoryId",
      "value": "2"
    },
    {
      "key": "tagId",
      "value": "1"
    }
  ]
}
